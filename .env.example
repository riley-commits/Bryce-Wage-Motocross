# ---------------------------------------------------------------------------
# Bryce Wage Motocross — environment variables
# Copy to .env.local for local dev. In production, set these in Vercel.
# ---------------------------------------------------------------------------

# Supabase --------------------------------------------------------------------
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Service role key — SERVER ONLY. Never expose to the browser.
# Get from the same API settings page. Click "Reveal" next to `service_role`.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Twilio ---------------------------------------------------------------------
# Get from https://console.twilio.com — Account SID and Auth Token on the dashboard.
# TWILIO_FROM_NUMBER must be a Twilio-purchased number in E.164 format (+1...).
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_FROM_NUMBER=+15555555555

# Admin auth -----------------------------------------------------------------
# Bcrypt hash of the admin password. Generate with:
#   npm run hash-password -- "your-password-here"
# It's safe to commit the HASH (not the plain password) to Vercel env vars.
ADMIN_PASSWORD_HASH=$2a$10$xxxxx

# 32+ character random string for signing the admin session cookie.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string-at-least-32-characters

# Site -----------------------------------------------------------------------
# Public URL of the deployed site. Used to build the order admin link
# included in the SMS notification. Set per-environment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
